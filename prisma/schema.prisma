  compLeaveRolloverMax        Int      @default(0)     @map("comp_leave_rollover_max")      // 補休遞延上限天數
  compLeaveExpiryMonths       Int      @default(6)     @map("comp_leave_expiry_months")     // 補休有效月數
  
  // 生效與狀態
  effectiveDate               DateTime @map("effective_date")
  isActive                    Boolean  @default(true) @map("is_active")
  description                 String?
  
  createdAt                   DateTime @default(now()) @map("created_at")
  updatedAt                   DateTime @updatedAt @map("updated_at")
  
  @@map("leave_rules_configs")
}

// 登入日誌
