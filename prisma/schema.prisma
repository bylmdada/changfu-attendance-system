// 審計日誌表 - 記錄所有敏感操作
model AuditLog {
  id          Int      @id @default(autoincrement())
  userId      Int?     @map("user_id")
  employeeId  Int?     @map("employee_id")
  action      String   // 操作類型：CLOCK_IN, CLOCK_OUT, LOGIN, SETTINGS_UPDATE 等
  targetType  String?  @map("target_type")   // 目標類型：AttendanceRecord, AllowedLocation, Employee 等
  targetId    Int?     @map("target_id")     // 目標記錄 ID
  oldValue    String?  @map("old_value")     // 修改前的值（JSON 格式）
  newValue    String?  @map("new_value")     // 修改後的值（JSON 格式）
  description String?                        // 操作描述
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  success     Boolean  @default(true)        // 操作是否成功
  errorMsg    String?  @map("error_msg")     // 失敗時的錯誤訊息
  
  // 風險評估欄位
  riskLevel   String   @default("LOW") @map("risk_level")  // LOW, MEDIUM, HIGH, CRITICAL
  isFlagged   Boolean  @default(false) @map("is_flagged")
  
  createdAt   DateTime @default(now()) @map("created_at")

  user        User?     @relation(fields: [userId], references: [id])
  employee    Employee? @relation(fields: [employeeId], references: [id])

  @@index([userId])
  @@index([employeeId])
  @@index([action])
  @@index([createdAt])
  @@index([success])
  @@index([isFlagged])
  @@map("audit_logs")
}

