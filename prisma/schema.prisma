  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([ipAddress, reason])
  @@index([blockedUntil])
  @@map("ip_blocks")
}

// 補休餘額（每位員工一筆）
model CompLeaveBalance {
  id          Int      @id @default(autoincrement())
  employeeId  Int      @unique @map("employee_id")
  totalEarned Float    @default(0) @map("total_earned")  // 累計獲得時數（已凍結）
  totalUsed   Float    @default(0) @map("total_used")    // 累計使用時數（已凍結）
  balance     Float    @default(0)                       // 可用餘額
  pendingEarn Float    @default(0) @map("pending_earn")  // 待確認獲得（未凍結）
  pendingUse  Float    @default(0) @map("pending_use")   // 待確認使用（未凍結）
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  employee Employee @relation(fields: [employeeId], references: [id])
  
  @@map("comp_leave_balances")
}

// 補休交易明細
model CompLeaveTransaction {
  id              Int      @id @default(autoincrement())
  employeeId      Int      @map("employee_id")
  transactionType String   @map("transaction_type")   // EARN, USE, SETTLE, EXPIRE
  hours           Float                               // 時數（正值）
  isFrozen        Boolean  @default(false) @map("is_frozen") // 是否已凍結確認
  referenceId     Int?     @map("reference_id")       // 關聯 ID
  referenceType   String?  @map("reference_type")     // OVERTIME, LEAVE, RESIGNATION
  yearMonth       String   @map("year_month")         // 歸屬月份 YYYY-MM
  description     String?
  createdAt       DateTime @default(now()) @map("created_at")
  
  employee Employee @relation(fields: [employeeId], references: [id])
  
  @@index([employeeId, yearMonth])
  @@index([isFrozen])
  @@map("comp_leave_transactions")
}

// 離職結算記錄
model ResignationSettlement {
  id             Int      @id @default(autoincrement())
  employeeId     Int      @unique @map("employee_id")
  compLeaveHours Float    @map("comp_leave_hours")   // 剩餘補休時數
  hourlyRate     Float    @map("hourly_rate")        // 每小時費率
  totalAmount    Float    @map("total_amount")       // 結算金額
  settlementDate DateTime @map("settlement_date")
  processedBy    Int      @map("processed_by")
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  
  employee  Employee @relation(fields: [employeeId], references: [id])
  processor Employee @relation("SettlementProcessor", fields: [processedBy], references: [id])
  
  @@map("resignation_settlements")
}

// ==================== 進階功能模型 ====================

// 加班打卡記錄
model OvertimeClockRecord {
  id          Int      @id @default(autoincrement())
  employeeId  Int      @map("employee_id")
  clockType   String   @map("clock_type")      // START, END
  clockTime   DateTime @map("clock_time")
  
  latitude    Float?
  longitude   Float?
  accuracy    Float?                          // GPS 精度（公尺）
  
  isValid     Boolean  @default(true) @map("is_valid")
  invalidReason String? @map("invalid_reason")
  
  // 關聯到加班申請（結束打卡時自動建立）
  overtimeRequestId Int? @map("overtime_request_id")
  
  createdAt   DateTime @default(now()) @map("created_at")
  
  employee Employee @relation(fields: [employeeId], references: [id])
  
  @@index([employeeId, clockTime])
  @@map("overtime_clock_records")
}

// 審批流程設定
model ApprovalFlow {
  id           Int      @id @default(autoincrement())
  name         String                        // 流程名稱
  resourceType String   @map("resource_type") // LEAVE, OVERTIME, SHIFT_EXCHANGE
  isActive     Boolean  @default(true) @map("is_active")
  
  // JSON: 審核步驟設定
  // [{ step: 1, role: "SUPERVISOR", required: true }, { step: 2, role: "HR", required: false }]
  steps        String
  
  // JSON: 自動核准規則
  // { maxDays: 3, autoApprove: true }
  autoApproveRules String? @map("auto_approve_rules")
  
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  
  @@unique([resourceType])
  @@map("approval_flows")
}

// 代理審核設定
model ApprovalDelegate {
  id          Int      @id @default(autoincrement())
  delegatorId Int      @map("delegator_id")   // 委託人
  delegateId  Int      @map("delegate_id")    // 代理人
  
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  
  resourceTypes String? @map("resource_types") // JSON: ["LEAVE", "OVERTIME"] 或 null 表示全部
  isActive    Boolean  @default(true) @map("is_active")
  
  createdAt   DateTime @default(now()) @map("created_at")
  
  delegator   Employee @relation("Delegator", fields: [delegatorId], references: [id])
  delegate    Employee @relation("Delegate", fields: [delegateId], references: [id])
  
  @@index([delegatorId, isActive])
  @@index([delegateId, isActive])
  @@map("approval_delegates")
}

// 薪資結算項目明細
model PayrollSettlementItem {
  id              Int      @id @default(autoincrement())
  payrollRecordId Int      @map("payroll_record_id")
  
