  sickLeaveNoDeductDays       Int      @default(10)    @map("sick_leave_no_deduct_days")    // 免扣全勤天數
  sickLeaveHalfPay            Boolean  @default(true)  @map("sick_leave_half_pay")          // 是否半薪
  
  // 特休假設定
