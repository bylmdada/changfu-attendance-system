  @@map("positions")
}

// ==================== 離職管理模型 ====================

// 離職申請記錄
model ResignationRecord {
  id              Int       @id @default(autoincrement())
  employeeId      Int       @map("employee_id")
  applicationDate DateTime  @default(now()) @map("application_date")
  expectedDate    DateTime  @map("expected_date")      // 預計離職日
  actualDate      DateTime? @map("actual_date")        // 實際離職日
  reason          String                               // 離職原因詳述
  reasonType      String    @default("VOLUNTARY") @map("reason_type") // VOLUNTARY/LAYOFF/RETIREMENT/OTHER
  status          String    @default("PENDING")        // PENDING/APPROVED/REJECTED/IN_HANDOVER/COMPLETED
  approvedById    Int?      @map("approved_by_id")
  approvedAt      DateTime? @map("approved_at")
  rejectionReason String?   @map("rejection_reason")   // 拒絕原因
  notes           String?
