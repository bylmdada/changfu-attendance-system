generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Employee {
  id               Int      @id @default(autoincrement())
  employeeId       String   @unique @map("employee_id")
  name             String
  birthday         DateTime
  phone            String?
  email            String?    // 員工 Email（用於通知）
  address          String?
  emergencyContact String?  @map("emergency_contact")
  emergencyPhone   String?  @map("emergency_phone")
  hireDate         DateTime @map("hire_date")
  baseSalary       Float    @map("base_salary")
  hourlyRate       Float    @map("hourly_rate")
  department       String?
  position         String?
  isActive         Boolean  @default(true) @map("is_active")
  managedLocation  String?  @map("managed_location")  // 據點排班員負責的據點
  
  // 員工類型：MONTHLY（月薪人員）、HOURLY（計時人員）
  employeeType     String   @default("MONTHLY") @map("employee_type")
  
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // 新增：保險與勞退相關欄位
  insuredBase          Float? @map("insured_base")
  dependents           Int?   @default(0) // 健保眷屬人數
  laborPensionSelfRate Float? @map("labor_pension_self_rate")
  
  // 勞保設定（個別設定，計時人員可能不參加）
  laborInsuranceActive Boolean @default(true) @map("labor_insurance_active")
  laborInsuranceNote   String? @map("labor_insurance_note")  // 不參加原因說明
  
  // 新增：健保投保資訊
  healthInsuranceActive Boolean @default(true) @map("health_insurance_active")
  healthInsuranceStartDate DateTime? @map("health_insurance_start_date")
  healthInsuranceEndDate   DateTime? @map("health_insurance_end_date")

  // 新增：銀行帳戶資訊（薪轉用）
  idNumber     String?  @map("id_number")      // 身分證字號（加密儲存）
  bankCode     String?  @default("806") @map("bank_code")  // 銀行代碼（806=元大）
  bankAccount  String?  @map("bank_account")   // 銀行帳號

  user              User?
  annualLeaves      AnnualLeave[]
  leaveRequests     LeaveRequest[]
  overtimeRequests  OvertimeRequest[]
  attendanceRecords AttendanceRecord[]
  payrollRecords    PayrollRecord[]
  announcements     Announcement[]
  schedules         Schedule[]
  passwordExceptions PasswordException[]
  
  // 新增調班關聯
  shiftExchangeRequestsMade    ShiftExchangeRequest[] @relation("ShiftExchangeRequester")
  shiftExchangeRequestsTarget  ShiftExchangeRequest[] @relation("ShiftExchangeTarget")
  shiftExchangeRequestsApproved ShiftExchangeRequest[] @relation("ShiftExchangeApprover")
  
  // GPS 打卡权限关联
  gpsPermissions GPSAttendancePermission[]

  // 新增審核關聯
  approvedLeaveRequests   LeaveRequest[]   @relation("LeaveRequestApprover")
  approvedOvertimeRequests OvertimeRequest[] @relation("OvertimeRequestApprover")

  attendanceFreezes AttendanceFreeze[]
  
  // 新增獎金相關關聯
  annualBonusRecords EmployeeAnnualBonus[]
  bonusRecords       BonusRecord[]
  createdBonusRecords BonusRecord[] @relation("BonusRecordCreator")

  // 健保眷屬關聯
  healthInsuranceDependents HealthInsuranceDependent[]
  
  // 考勤權限關聯
  attendancePermission AttendancePermission?

  // 忘打卡申請關聯
  missedClockRequests MissedClockRequest[]

  // 操作紀錄關聯
  auditLogs AuditLog[]

  // 補休餘額與離職結算關聯
  compLeaveBalance        CompLeaveBalance?
  compLeaveTransactions   CompLeaveTransaction[]
  resignationSettlement   ResignationSettlement?
  processedSettlements    ResignationSettlement[] @relation("SettlementProcessor")

  // 離職申請關聯
  resignationRecords      ResignationRecord[]

  // 加班打卡關聯
  overtimeClockRecords    OvertimeClockRecord[]
  
  // 代理審核關聯
  delegatedFrom           ApprovalDelegate[] @relation("Delegator")
  delegatedTo             ApprovalDelegate[] @relation("Delegate")

  // 通知關聯
  notifications           Notification[]
  notificationSettings    NotificationSettings?

  // 請購單關聯
  purchaseRequests        PurchaseRequest[]
  approvedPurchaseRequests PurchaseRequest[] @relation("PurchaseRequestApprover")

  // 年假餘額歷史關聯
  leaveBalanceHistory     LeaveBalanceHistory[]

  // 系統內通知關聯
  inAppNotifications      InAppNotification[]

  // 國定假日補休關聯
  holidayCompensations    HolidayCompensation[]

  // 薪資異議申請關聯
  payrollDisputes         PayrollDispute[]
  reviewedDisputes        PayrollDispute[] @relation("DisputeReviewer")
  createdAdjustments      PayrollAdjustment[] @relation("AdjustmentCreator")
  
  // 天災假關聯
  createdDisasterDayOffs  DisasterDayOff[] @relation("DisasterDayOffCreator")

  // 審核流程關聯
  departmentManagers      DepartmentManager[]
  managerDeputies         ManagerDeputy[] @relation("DeputyEmployee")
  approvalReviews         ApprovalReview[]
  ccsSent                 ApprovalCC[] @relation("CCBy")      // 發起的 CC
  ccsReceived             ApprovalCC[] @relation("CCTo")      // 接收的 CC

  // 薪資歷史關聯
  salaryHistories         SalaryHistory[]
  approvedSalaryChanges   SalaryHistory[] @relation("SalaryApprover")

  // 班表確認關聯
  scheduleReleases        ScheduleMonthlyRelease[] @relation("ScheduleReleasePublisher")
  scheduleConfirmations   ScheduleConfirmation[] @relation("ScheduleConfirmEmployee")

  // 勞退自提申請關聯
  pensionApplications     PensionContributionApplication[]
  reviewedPensionApps     PensionContributionApplication[] @relation("PensionHRReviewer")
  approvedPensionApps     PensionContributionApplication[] @relation("PensionAdminApprover")

  @@map("employees")
}

// 請購單
model PurchaseRequest {
  id              Int       @id @default(autoincrement())
  requestNumber   String    @unique @map("request_number")  // 單號 PR-YYYYMM-NNN
  employeeId      Int       @map("employee_id")             // 申請人
  department      String                                     // 部門
  title           String                                     // 採購主旨
  category        String    @default("OTHER")               // 類別: MEDICAL/CARE_SUPPLIES/OFFICE/IT_EQUIPMENT/FURNITURE/CLEANING/FOOD/KITCHEN/MAINTENANCE/UNIFORM/ACTIVITY/OTHER
  items           String                                     // 採購項目 (JSON 格式)
  totalAmount     Float     @map("total_amount")            // 預估總金額
  reason          String                                     // 採購原因
  status          String    @default("PENDING")             // PENDING/APPROVED/REJECTED
  priority        String    @default("NORMAL")              // LOW/NORMAL/HIGH/URGENT
  approvedBy      Int?      @map("approved_by")             // 審核人
  approvedAt      DateTime? @map("approved_at")             // 審核時間
  rejectReason    String?   @map("reject_reason")           // 駁回原因
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  employee        Employee  @relation(fields: [employeeId], references: [id])
  approver        Employee? @relation("PurchaseRequestApprover", fields: [approvedBy], references: [id])

  @@map("purchase_requests")
}

model User {
  id           Int       @id @default(autoincrement())
  employeeId   Int       @unique @map("employee_id")
  username     String    @unique
  passwordHash String    @map("password_hash")
  role         String    @default("EMPLOYEE")
  lastLogin    DateTime? @map("last_login")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")

  // 2FA 雙因素驗證
  twoFactorEnabled Boolean  @default(false) @map("two_factor_enabled")
  twoFactorSecret  String?  @map("two_factor_secret")
  backupCodes      String?  @map("backup_codes") // JSON 格式儲存

  // 單一會話登入控制
  currentSessionId String?  @map("current_session_id") // 當前有效的會話 ID

  employee Employee @relation(fields: [employeeId], references: [id])
  
  // GPS 打卡权限创建关联
  createdGPSPermissions GPSAttendancePermission[]

  // 忘打卡申請審核關聯
  approvedMissedClockRequests MissedClockRequest[]

  // 密碼例外創建關聯
  createdPasswordExceptions PasswordException[]

  // 操作紀錄關聯
  auditLogs AuditLog[]

  // 登入日誌關聯
  loginLogs LoginLog[]

  // WebAuthn 生物識別憑證關聯
  webauthnCredentials WebAuthnCredential[]

  @@map("users")
}

// WebAuthn 生物識別憑證（Face ID / 指紋）
model WebAuthnCredential {
  id              Int      @id @default(autoincrement())
  credentialId    String   @unique @map("credential_id") // Base64 編碼的憑證 ID
  publicKey       String   @map("public_key") // Base64 編碼的公鑰
  counter         Int      @default(0) // 防重放攻擊計數器
  deviceName      String?  @map("device_name") // 裝置名稱（如 iPhone 12）
  transports      String?  // JSON 陣列：["internal", "hybrid"] 等
  userId          Int      @map("user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  lastUsedAt      DateTime? @map("last_used_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("webauthn_credentials")
}

model AnnualLeave {
  id              Int     @id @default(autoincrement())
  employeeId      Int     @map("employee_id")
  year            Int
  yearsOfService  Int     @map("years_of_service")
  totalDays       Int     @map("total_days")
  usedDays        Float   @default(0) @map("used_days")
  remainingDays   Float   @map("remaining_days")
  expiryDate      DateTime @map("expiry_date")
  createdAt       DateTime @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, year])
  @@map("annual_leaves")
}

model LeaveRequest {
  id              Int           @id @default(autoincrement())
  employeeId      Int           @map("employee_id")
  leaveType       String        @map("leave_type")
  startDate       DateTime      @map("start_date")
  endDate         DateTime      @map("end_date")
  totalDays       Float         @map("total_days")
  reason          String?
  status          String        @default("PENDING")  // PENDING/PENDING_ADMIN/APPROVED/REJECTED/CANCELLED/VOIDED
  approvedBy      Int?          @map("approved_by")
  approvedAt      DateTime?     @map("approved_at")
  createdAt       DateTime      @default(now()) @map("created_at")

  // 主管審核欄位（二階審核）
  managerReviewerId  Int?       @map("manager_reviewer_id")
  managerOpinion     String?    @map("manager_opinion")  // AGREE/DISAGREE
  managerNote        String?    @map("manager_note")
  managerReviewedAt  DateTime?  @map("manager_reviewed_at")

  // 撤銷申請相關欄位
  cancellationStatus        String?   @map("cancellation_status")  // PENDING_MANAGER/PENDING_ADMIN/APPROVED/REJECTED
  cancellationReason        String?   @map("cancellation_reason")
  cancellationRequestedAt   DateTime? @map("cancellation_requested_at")
  cancellationHRReviewerId  Int?      @map("cancellation_hr_reviewer_id")
  cancellationHROpinion     String?   @map("cancellation_hr_opinion")  // AGREE/DISAGREE
  cancellationHRNote        String?   @map("cancellation_hr_note")
  cancellationHRReviewedAt  DateTime? @map("cancellation_hr_reviewed_at")
  cancellationAdminApproverId Int?    @map("cancellation_admin_approver_id")
  cancellationAdminNote     String?   @map("cancellation_admin_note")
  cancellationApprovedAt    DateTime? @map("cancellation_approved_at")

  // 直接作廢相關欄位
  voidedBy        Int?          @map("voided_by")
  voidedAt        DateTime?     @map("voided_at")
  voidReason      String?       @map("void_reason")

  employee Employee @relation(fields: [employeeId], references: [id])
  approver Employee? @relation("LeaveRequestApprover", fields: [approvedBy], references: [id])

  @@map("leave_requests")
}

model OvertimeRequest {
  id               Int           @id @default(autoincrement())
  employeeId       Int           @map("employee_id")
  overtimeDate     DateTime      @map("overtime_date")
  startTime        String        @map("start_time")
  endTime          String        @map("end_time")
  totalHours       Float         @map("total_hours")
  reason           String
  workContent      String?       @map("work_content")
  status           String        @default("PENDING")  // PENDING/PENDING_ADMIN/APPROVED/REJECTED/CANCELLED/VOIDED
  compensationType String        @default("COMP_LEAVE") @map("compensation_type") // 補償方式：COMP_LEAVE(補休) 或 OVERTIME_PAY(加班費)
  
  // 加班費相關欄位
  overtimeType     String?       @map("overtime_type")      // 加班類型：WEEKDAY/REST_DAY/HOLIDAY
  overtimePay      Float?        @map("overtime_pay")       // 計算後的加班費金額
  hourlyRateUsed   Float?        @map("hourly_rate_used")   // 計算時使用的時薪
  
  approvedBy       Int?          @map("approved_by")
  approvedAt       DateTime?     @map("approved_at")
  createdAt        DateTime      @default(now()) @map("created_at")

  // 主管審核欄位（二階審核）
  managerReviewerId  Int?        @map("manager_reviewer_id")
  managerOpinion     String?     @map("manager_opinion")  // AGREE/DISAGREE
  managerNote        String?     @map("manager_note")
  managerReviewedAt  DateTime?   @map("manager_reviewed_at")

  // 撤銷申請相關欄位
  cancellationStatus        String?   @map("cancellation_status")  // PENDING_MANAGER/PENDING_ADMIN/APPROVED/REJECTED
  cancellationReason        String?   @map("cancellation_reason")
  cancellationRequestedAt   DateTime? @map("cancellation_requested_at")
  cancellationHRReviewerId  Int?      @map("cancellation_hr_reviewer_id")
  cancellationHROpinion     String?   @map("cancellation_hr_opinion")  // AGREE/DISAGREE
  cancellationHRNote        String?   @map("cancellation_hr_note")
  cancellationHRReviewedAt  DateTime? @map("cancellation_hr_reviewed_at")
  cancellationAdminApproverId Int?    @map("cancellation_admin_approver_id")
  cancellationAdminNote     String?   @map("cancellation_admin_note")
  cancellationApprovedAt    DateTime? @map("cancellation_approved_at")

  // 直接作廢相關欄位
  voidedBy         Int?          @map("voided_by")
  voidedAt         DateTime?     @map("voided_at")
  voidReason       String?       @map("void_reason")

  // 補休回沖記錄
  compLeaveReversed Boolean      @default(false) @map("comp_leave_reversed")
  compLeaveReversedAt DateTime?  @map("comp_leave_reversed_at")

  employee Employee @relation(fields: [employeeId], references: [id])
  approver Employee? @relation("OvertimeRequestApprover", fields: [approvedBy], references: [id])

  @@map("overtime_requests")
}

model AttendanceRecord {
  id            Int              @id @default(autoincrement())
  employeeId    Int              @map("employee_id")
  workDate      DateTime         @map("work_date")
  clockInTime   DateTime?        @map("clock_in_time")
  clockOutTime  DateTime?        @map("clock_out_time")
  
  // GPS位置資訊 - 打卡時位置
  clockInLatitude  Float?        @map("clock_in_latitude")   // 打卡時緯度
  clockInLongitude Float?        @map("clock_in_longitude")  // 打卡時經度
  clockInAccuracy  Float?        @map("clock_in_accuracy")   // 打卡時GPS精確度(米)
  clockInAddress   String?       @map("clock_in_address")    // 打卡時地址
  
  // GPS位置資訊 - 下班打卡位置
  clockOutLatitude  Float?       @map("clock_out_latitude")  // 下班時緯度
  clockOutLongitude Float?       @map("clock_out_longitude") // 下班時經度
  clockOutAccuracy  Float?       @map("clock_out_accuracy")  // 下班時GPS精確度(米)
  clockOutAddress   String?      @map("clock_out_address")   // 下班時地址
  
  regularHours  Float?           @map("regular_hours")
  overtimeHours Float?           @map("overtime_hours")
  
  // 提早上班/延後下班原因記錄
  clockInReason     String?      @map("clock_in_reason")     // 'PERSONAL' | 'BUSINESS' - 提早上班原因
  clockOutReason    String?      @map("clock_out_reason")    // 'PERSONAL' | 'BUSINESS' - 延後下班原因
  clockInOvertimeId Int?         @map("clock_in_overtime_id")  // 關聯的加班申請 ID (提早上班)
  clockOutOvertimeId Int?        @map("clock_out_overtime_id") // 關聯的加班申請 ID (延後下班)
  
  status        String           @default("PRESENT")
  notes         String?
  createdAt     DateTime         @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, workDate])
  @@map("attendance_records")
}

// 薪資歷史記錄（用於追蹤調薪）
model SalaryHistory {
  id               Int       @id @default(autoincrement())
  employeeId       Int       @map("employee_id")
  effectiveDate    DateTime  @map("effective_date")    // 生效日期
  baseSalary       Float     @map("base_salary")       // 月薪
  hourlyRate       Float     @map("hourly_rate")       // 時薪（= 月薪 ÷ 240）
  previousSalary   Float?    @map("previous_salary")   // 調薪前月薪
  adjustmentAmount Float?    @map("adjustment_amount") // 調整金額
  adjustmentType   String    @default("INITIAL") @map("adjustment_type") 
                             // INITIAL=初始, RAISE=調薪, PROMOTION=晉升, ADJUSTMENT=調整
  reason           String?                              // 調整原因
  approvedById     Int       @map("approved_by_id")    // 核准人（管理員）
  createdAt        DateTime  @default(now()) @map("created_at")
  notes            String?                              // 備註
  
  employee   Employee @relation(fields: [employeeId], references: [id])
  approvedBy Employee @relation("SalaryApprover", fields: [approvedById], references: [id])
  
  @@index([employeeId, effectiveDate])
  @@map("salary_histories")
}

model PayrollRecord {
  id             Int      @id @default(autoincrement())
  employeeId     Int      @map("employee_id")
  payYear        Int      @map("pay_year")
  payMonth       Int      @map("pay_month")
  regularHours   Float    @map("regular_hours")
  overtimeHours  Float    @map("overtime_hours")
  
  // 詳細加班時數分類（依據勞基法）
  weekdayOvertimeHours     Float @default(0) @map("weekday_overtime_hours")     // 平日加班時數
  restDayOvertimeHours     Float @default(0) @map("rest_day_overtime_hours")     // 休息日加班時數  
  holidayOvertimeHours     Float @default(0) @map("holiday_overtime_hours")     // 國定假日加班時數
  mandatoryRestOvertimeHours Float @default(0) @map("mandatory_rest_overtime_hours") // 例假日加班時數
  
  basePay        Float    @map("base_pay")
  overtimePay    Float    @map("overtime_pay")
  
  // 詳細加班費分類
  weekdayOvertimePay       Float @default(0) @map("weekday_overtime_pay")       // 平日加班費
  restDayOvertimePay       Float @default(0) @map("rest_day_overtime_pay")       // 休息日加班費
  holidayOvertimePay       Float @default(0) @map("holiday_overtime_pay")       // 國定假日加班費
  mandatoryRestOvertimePay Float @default(0) @map("mandatory_rest_overtime_pay") // 例假日加班費
  
  grossPay       Float    @map("gross_pay")
  laborInsurance Float    @default(0) @map("labor_insurance")
  healthInsurance Float   @default(0) @map("health_insurance")
  supplementaryInsurance Float @default(0) @map("supplementary_insurance")
  laborPensionSelf Float  @default(0) @map("labor_pension_self") // 勞退自提金額
  incomeTax      Float    @default(0) @map("income_tax")
  totalDeductions Float   @default(0) @map("total_deductions")
  netPay         Float    @map("net_pay")
  
  // 計算詳細資訊（JSON格式存儲）
  hourlyWage             Float @map("hourly_wage")                              // 平日每小時工資額
  overtimeCalculationDetails Json? @map("overtime_calculation_details")         // 加班費計算詳細資訊
  deductionDetails       Json? @map("deduction_details")                       // 扣除項目詳細資訊
  calculationNotes       Json? @map("calculation_notes")                       // 計算備註
  
  // 新增：健保費計算詳細資訊
  healthInsuranceDetails Json? @map("health_insurance_details") // 存儲健保費計算詳情
  dependentsCountUsed    Int?  @default(0) @map("dependents_count_used") // 當月實際計算使用的眷屬人數
  
  createdAt      DateTime @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id])

  // 新增：薪資項目關聯
  payrollItems PayrollItem[]
  
  // 新增：結算項目關聯
  settlementItems PayrollSettlementItem[]

  // 新增：薪資異議與調整關聯
  disputes    PayrollDispute[]
  adjustments PayrollAdjustment[]

  @@unique([employeeId, payYear, payMonth])
  @@map("payroll_records")
}

model Announcement {
  id          Int      @id @default(autoincrement())
  title       String
  content     String
  priority    String   @default("NORMAL") // HIGH, NORMAL, LOW
  category    String   @default("GENERAL") // PERSONNEL, POLICY, EVENT, SYSTEM, BENEFITS, URGENT, GENERAL
  publisherId Int      @map("publisher_id")
  isPublished Boolean  @default(false) @map("is_published")
  publishedAt DateTime? @map("published_at")
  expiryDate  DateTime? @map("expiry_date")
  
  // 定時發布設定
  scheduledPublishAt DateTime? @map("scheduled_publish_at") // 預定發布時間，null 表示不使用定時發布
  
  // 新增：目標部門設定（支援多部門或全部部門）
  targetDepartments String? @map("target_departments") // JSON格式存儲部門列表，null表示全部部門
  isGlobalAnnouncement Boolean @default(false) @map("is_global_announcement") // 是否為全員通告
  
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  publisher   Employee @relation(fields: [publisherId], references: [id])
  attachments AnnouncementAttachment[]

  @@map("announcements")
}

model AnnouncementAttachment {
  id             Int      @id @default(autoincrement())
  announcementId Int      @map("announcement_id")
  fileName       String   @map("file_name")
  originalName   String   @map("original_name")
  filePath       String   @map("file_path")
  fileSize       Int      @map("file_size")
  mimeType       String   @map("mime_type")
  createdAt      DateTime @default(now()) @map("created_at")

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@map("announcement_attachments")
}

model Schedule {
  id         Int      @id @default(autoincrement())
  employeeId Int      @map("employee_id")
  workDate   String   @map("work_date") // 使用 String 格式 YYYY-MM-DD
  shiftType  String   @map("shift_type")
  startTime  String   @map("start_time")
  endTime    String   @map("end_time")
  breakTime  Int      @default(0) @map("break_time")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

