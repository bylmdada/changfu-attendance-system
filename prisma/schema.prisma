// 系統通知設定
model SystemNotificationSettings {
  id                      Int      @id @default(autoincrement())
  emailEnabled            Boolean  @default(false)  @map("email_enabled")
  inAppEnabled            Boolean  @default(true)   @map("in_app_enabled")
  leaveApprovalNotify     Boolean  @default(true)   @map("leave_approval_notify")
  overtimeApprovalNotify  Boolean  @default(true)   @map("overtime_approval_notify")
  shiftApprovalNotify     Boolean  @default(true)   @map("shift_approval_notify")
  annualLeaveExpiryNotify Boolean  @default(true)   @map("annual_leave_expiry_notify")
  annualLeaveExpiryDays   Int      @default(90)     @map("annual_leave_expiry_days")  // 開始提醒的天數
  
  // 分階段提醒設定 (JSON 格式: [{daysFrom: 90, daysTo: 60, intervalDays: 30}, ...])
  reminderStages          String?  @map("reminder_stages")
  
  createdAt               DateTime @default(now())  @map("created_at")
  updatedAt               DateTime @updatedAt       @map("updated_at")
  
  @@map("system_notification_settings")
}

// 年假提醒記錄（避免重複發送）
model LeaveExpiryReminderLog {
  id            Int      @id @default(autoincrement())
  employeeId    Int      @map("employee_id")
  annualLeaveId Int      @map("annual_leave_id")
  year          Int                               // 年假年度
  stage         Int                               // 提醒階段 (1, 2, 3, 4)
  sentAt        DateTime @default(now()) @map("sent_at")
  channel       String                            // EMAIL, IN_APP, BOTH
  
  @@unique([employeeId, annualLeaveId, stage])
  @@index([employeeId])
  @@index([annualLeaveId])
  @@index([sentAt])
  @@map("leave_expiry_reminder_logs")
}

// 系統內通知
model InAppNotification {
  id          Int      @id @default(autoincrement())
  employeeId  Int      @map("employee_id")
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type        String                              // LEAVE_APPROVED, OVERTIME_APPROVED, etc.
  title       String                              // 通知標題
  message     String                              // 通知內容
  data        String?                             // JSON 格式的額外資料
  isRead      Boolean  @default(false) @map("is_read")
  readAt      DateTime? @map("read_at")
  createdAt   DateTime @default(now())  @map("created_at")
  
  @@index([employeeId])
  @@index([isRead])
  @@index([createdAt])
  @@map("in_app_notifications")
}

// 薪資異議申請
model PayrollDispute {
  id              Int       @id @default(autoincrement())
  employeeId      Int       @map("employee_id")
  payrollId       Int?      @map("payroll_id")             // 關聯薪資記錄（若有）
  payYear         Int       @map("pay_year")               // 異議的薪資年份
  payMonth        Int       @map("pay_month")              // 異議的薪資月份
  type            String                                    // OVERTIME_MISSING/LEAVE_MISSING/CALCULATION_ERROR/ALLOWANCE_MISSING/DEDUCTION_ERROR/OTHER
  description     String                                    // 異議說明
  requestedAmount Float?    @map("requested_amount")       // 申請調整金額
  fileUrl         String?   @map("file_url")               // 附件（證明文件）
  status          String    @default("PENDING")            // PENDING/APPROVED/REJECTED
  reviewedBy      Int?      @map("reviewed_by")
  reviewedAt      DateTime? @map("reviewed_at")
  reviewNote      String?   @map("review_note")            // 審核備註
  adjustedAmount  Float?    @map("adjusted_amount")        // 實際核准調整金額
  adjustInYear    Int?      @map("adjust_in_year")         // 調整計入哪年薪資
  adjustInMonth   Int?      @map("adjust_in_month")        // 調整計入哪月薪資
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  employee        Employee  @relation(fields: [employeeId], references: [id])
  payroll         PayrollRecord? @relation(fields: [payrollId], references: [id])
  reviewer        Employee? @relation("DisputeReviewer", fields: [reviewedBy], references: [id])
  adjustment      PayrollAdjustment?

  @@index([employeeId])
  @@index([payrollId])
  @@index([status])
  @@index([payYear, payMonth])
  @@map("payroll_disputes")
}

// 薪資調整項目（會顯示在薪資條上）
model PayrollAdjustment {
  id              Int       @id @default(autoincrement())
  payrollId       Int       @map("payroll_id")             // 計入哪個月薪資
  disputeId       Int?      @unique @map("dispute_id")     // 關聯的異議申請（若有）
  type            String                                    // SUPPLEMENT(補發) / DEDUCTION(扣除)
  category        String                                    // OVERTIME/LEAVE/BONUS/ALLOWANCE/OTHER
  description     String                                    // 顯示在薪資條上的說明
  amount          Float                                     // 金額（正數）
  originalYear    Int?      @map("original_year")          // 原始年份
  originalMonth   Int?      @map("original_month")         // 原始月份
  createdBy       Int       @map("created_by")
  createdAt       DateTime  @default(now()) @map("created_at")

  payroll         PayrollRecord @relation(fields: [payrollId], references: [id])
  dispute         PayrollDispute? @relation(fields: [disputeId], references: [id])
  creator         Employee  @relation("AdjustmentCreator", fields: [createdBy], references: [id])

  @@index([payrollId])
  @@index([disputeId])
  @@map("payroll_adjustments")
}

// 天災假記錄
model DisasterDayOff {
  id                  Int       @id @default(autoincrement())
  disasterDate        String    @map("disaster_date")          // 停班日期 YYYY-MM-DD
  disasterType        String    @map("disaster_type")          // 類型: TYPHOON/EARTHQUAKE/RAIN/WIND/OTHER
  stopWorkType        String    @map("stop_work_type")         // 停班類型: FULL/AM/PM
  affectedScope       String    @default("ALL") @map("affected_scope") // 影響範圍: ALL/DEPARTMENTS/EMPLOYEES
  affectedDepartments String?   @map("affected_departments")   // JSON: ["部門1", "部門2"]
  affectedEmployeeIds String?   @map("affected_employee_ids")  // JSON: [1, 2, 3]
  description         String?                                   // 說明備註
  affectedCount       Int       @default(0) @map("affected_count") // 受影響人數
  originalSchedules   String?   @map("original_schedules")     // 原始班表JSON [{employeeId, shiftType, startTime, endTime}]
  createdBy           Int       @map("created_by")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  creator             Employee  @relation("DisasterDayOffCreator", fields: [createdBy], references: [id])

  @@unique([disasterDate, affectedScope])
  @@index([disasterDate])
  @@index([disasterType])
  @@map("disaster_day_offs")
}

// =====================================================
// 審核流程管理系統
// =====================================================

// 審核流程設定
model ApprovalWorkflow {
  id                  Int       @id @default(autoincrement())
  workflowType        String    @unique @map("workflow_type")
  // SHIFT_CHANGE, SHIFT_SWAP, MISSED_CLOCK, LEAVE, OVERTIME, 
  // PURCHASE, RESIGNATION, PAYROLL_DISPUTE, DEPENDENT_APP, ANNOUNCEMENT
  
  workflowName        String    @map("workflow_name")
  approvalLevel       Int       @default(2) @map("approval_level")      // 1=一階, 2=二階, 3=三階
  requireManager      Boolean   @default(true) @map("require_manager")  // 是否需主管審核
  finalApprover       String    @default("ADMIN") @map("final_approver") // MANAGER, ADMIN
  
  // 時效設定
  deadlineMode        String    @default("FIXED") @map("deadline_mode") // FIXED, FREEZE_BASED
  deadlineHours       Int?      @map("deadline_hours")                  // 固定時效（小時）
  
  // 轉會設定（預設關閉）
  enableForward       Boolean   @default(false) @map("enable_forward")         // 轉會給其他審核者
  enableCC            Boolean   @default(false) @map("enable_cc")              // CC 給員工知悉/同意
  
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  
  @@map("approval_workflows")
}

// 凍結提醒設定
model ApprovalFreezeReminder {
  id                    Int       @id @default(autoincrement())
  daysBeforeFreeze1     Int       @default(3) @map("days_before_freeze_1")
  daysBeforeFreeze2     Int       @default(1) @map("days_before_freeze_2")
  freezeDayReminderTime String    @default("09:00") @map("freeze_day_reminder_time")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  
  @@map("approval_freeze_reminders")
}

// 部門主管
model DepartmentManager {
  id              Int       @id @default(autoincrement())
  employeeId      Int       @map("employee_id")
  department      String
  isPrimary       Boolean   @default(true) @map("is_primary")
  
  // 權限設定
  canApproveLeave     Boolean @default(true) @map("can_approve_leave")
  canApproveOvertime  Boolean @default(true) @map("can_approve_overtime")
  canApproveShift     Boolean @default(true) @map("can_approve_shift")
  canApprovePurchase  Boolean @default(true) @map("can_approve_purchase")
  canSchedule         Boolean @default(true) @map("can_schedule")
  
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  
  employee        Employee  @relation(fields: [employeeId], references: [id])
  deputies        ManagerDeputy[]
  
  @@unique([employeeId, department])
  @@index([department])
  @@map("department_managers")
}

// 代理人設定
model ManagerDeputy {
  id                Int       @id @default(autoincrement())
  managerId         Int       @map("manager_id")
  deputyEmployeeId  Int       @map("deputy_employee_id")
  startDate         DateTime? @map("start_date")
  endDate           DateTime? @map("end_date")
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at")
  
  manager           DepartmentManager @relation(fields: [managerId], references: [id], onDelete: Cascade)
  deputyEmployee    Employee  @relation("DeputyEmployee", fields: [deputyEmployeeId], references: [id])
  
  @@index([managerId])
  @@index([deputyEmployeeId])
  @@map("manager_deputies")
}

// 審核實例
model ApprovalInstance {
  id              Int       @id @default(autoincrement())
  requestType     String    @map("request_type")
  requestId       Int       @map("request_id")
  
  applicantId     Int       @map("applicant_id")
  applicantName   String    @map("applicant_name")
  department      String?
  
  currentLevel    Int       @default(1) @map("current_level")
  maxLevel        Int       @map("max_level")
  requireManager  Boolean   @default(true) @map("require_manager")
  
  status          String    @default("PENDING")
  // PENDING, LEVEL1_REVIEWING, LEVEL1_APPROVED, LEVEL2_REVIEWING, APPROVED, REJECTED
  
  deadlineAt      DateTime? @map("deadline_at")
  reminderSent    Boolean   @default(false) @map("reminder_sent")
  isEscalated     Boolean   @default(false) @map("is_escalated")
  escalatedAt     DateTime? @map("escalated_at")
  
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  
  reviews         ApprovalReview[]
  ccs             ApprovalCC[]
  
  @@index([requestType, requestId])
  @@index([status])
  @@index([applicantId])
  @@map("approval_instances")
}

// 審核紀錄
model ApprovalReview {
  id              Int       @id @default(autoincrement())
  instanceId      Int       @map("instance_id")
  
  level           Int
  reviewerId      Int       @map("reviewer_id")
  reviewerName    String    @map("reviewer_name")
  reviewerRole    String    @map("reviewer_role")  // MANAGER, DEPUTY, HR, ADMIN
  isDeputy        Boolean   @default(false) @map("is_deputy")
  
  action          String    // APPROVE, REJECT, FORWARD
  comment         String?
  forwardToId     Int?      @map("forward_to_id")
  forwardReason   String?   @map("forward_reason")
  
  createdAt       DateTime  @default(now()) @map("created_at")
  
  instance        ApprovalInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  reviewer        Employee  @relation(fields: [reviewerId], references: [id])
  
  @@index([instanceId])
  @@index([reviewerId])
  @@map("approval_reviews")
}

// 審核 CC 記錄（轉會知悉/同意）
model ApprovalCC {
  id              Int       @id @default(autoincrement())
  instanceId      Int       @map("instance_id")
  
  // CC 來源
  ccByEmployeeId  Int       @map("cc_by_employee_id")  // 誰發起 CC
  ccByName        String    @map("cc_by_name")
  
  // CC 目標
  ccToEmployeeId  Int       @map("cc_to_employee_id")  // 被 CC 的員工
  ccToName        String    @map("cc_to_name")
  
  // CC 類型
  ccType          String    @default("ACKNOWLEDGE") @map("cc_type")  // ACKNOWLEDGE（知悉）, AGREE（同意）
  reason          String?                                             // CC 原因
  
  // 回應狀態
  status          String    @default("PENDING") @map("status")        // PENDING, ACKNOWLEDGED, AGREED
  respondedAt     DateTime? @map("responded_at")
  response        String?                                             // 回應內容
  
  createdAt       DateTime  @default(now()) @map("created_at")
  
  instance        ApprovalInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  ccBy            Employee  @relation("CCBy", fields: [ccByEmployeeId], references: [id])
  ccTo            Employee  @relation("CCTo", fields: [ccToEmployeeId], references: [id])
  
  @@index([instanceId])
  @@index([ccToEmployeeId])
  @@map("approval_ccs")
}

// 勞退自提申請
model PensionContributionApplication {
  id              Int       @id @default(autoincrement())
  employeeId      Int       @map("employee_id")
  
  // 提繳比例資訊
  currentRate     Float     @default(0) @map("current_rate")      // 目前提繳比例 (0-6%)
  requestedRate   Float     @map("requested_rate")                // 申請變更比例 (0-6%)
  
  // 生效日期（次月1日或隔月1日）
  effectiveDate   DateTime  @map("effective_date")
  applicationDate DateTime  @default(now()) @map("application_date")
  
  // 申請資訊
  reason          String?                                         // 申請原因
  
  // 審核狀態
  status          String    @default("PENDING_HR") @map("status") 
  // PENDING_HR（待HR審核）-> HR_APPROVED/HR_REJECTED（HR審核結果）-> PENDING_ADMIN（待管理員決核）-> APPROVED/REJECTED（最終結果）
  
  // HR 審核
  hrReviewerId    Int?      @map("hr_reviewer_id")
  hrReviewedAt    DateTime? @map("hr_reviewed_at")
  hrOpinion       String?   @map("hr_opinion")                    // HR審核意見：AGREE/DISAGREE
  hrNote          String?   @map("hr_note")                       // HR審核說明
  
  // 管理員決核
  adminApproverId Int?      @map("admin_approver_id")
  adminApprovedAt DateTime? @map("admin_approved_at")
  adminNote       String?   @map("admin_note")                    // 管理員決核說明
  
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  
  // 關聯
  employee        Employee  @relation(fields: [employeeId], references: [id])
  hrReviewer      Employee? @relation("PensionHRReviewer", fields: [hrReviewerId], references: [id])
  adminApprover   Employee? @relation("PensionAdminApprover", fields: [adminApproverId], references: [id])
  
  @@index([employeeId])
  @@index([status])
  @@index([effectiveDate])
  @@map("pension_contribution_applications")
}
