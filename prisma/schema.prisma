// 員工班表確認記錄
model ScheduleConfirmation {
  id           Int       @id @default(autoincrement())
  employeeId   Int       @map("employee_id")
  yearMonth    String    @map("year_month")       // 格式: 2025-01
  releaseId    Int       @map("release_id")
