  leaveApproval         Boolean @default(true)  @map("leave_approval")
  overtimeApproval      Boolean @default(true)  @map("overtime_approval")
  shiftExchangeApproval Boolean @default(true)  @map("shift_exchange_approval")
  systemAnnouncements   Boolean @default(true)  @map("system_announcements")
  
  // Push 推播訂閱資訊
  pushEnabled   Boolean  @default(false) @map("push_enabled")
  pushEndpoint  String?  @map("push_endpoint")
  pushP256dh    String?  @map("push_p256dh")
  pushAuth      String?  @map("push_auth")
  
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
