  enabled         Boolean  @default(false)
  smtpHost        String?  @map("smtp_host")
  smtpPort        Int?     @default(587) @map("smtp_port")
  smtpSecure      Boolean  @default(true) @map("smtp_secure")
  smtpUser        String?  @map("smtp_user")
  smtpPassword    String?  @map("smtp_password")
  fromEmail       String?  @map("from_email")
  fromName        String?  @default("薪資系統") @map("from_name")
  subjectTemplate String?  @default("[%YEAR%年%MONTH%月] 薪資條通知") @map("subject_template")
  bodyTemplate    String?  @map("body_template")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  @@map("payslip_email_settings")
}

// 薪資條發送歷史
model PayslipSendHistory {
  id            Int      @id @default(autoincrement())
  payrollId     Int      @map("payroll_id")
  employeeId    Int      @map("employee_id")
  employeeName  String   @map("employee_name")
  employeeEmail String   @map("employee_email")
  year          Int
  month         Int
  sentAt        DateTime @default(now()) @map("sent_at")
  status        String   // SUCCESS, FAILED
  errorMessage  String?  @map("error_message")
  sentBy        String?  @map("sent_by")
  
  @@index([employeeId])
  @@index([year, month])
  @@index([status])
  @@map("payslip_send_history")
}

// 眷屬加退保記錄
model DependentEnrollmentLog {
  id            Int       @id @default(autoincrement())
  dependentId   Int       @map("dependent_id")
  employeeId    Int       @map("employee_id")
  dependentName String    @map("dependent_name")
  employeeName  String    @map("employee_name")
  type          String    // ENROLL（加保）, WITHDRAW（退保）
  effectiveDate DateTime  @map("effective_date")
  reportStatus  String    @default("PENDING") @map("report_status") // PENDING, REPORTED, COMPLETED
  reportDate    DateTime? @map("report_date")
  remarks       String?
  createdBy     String    @map("created_by")
  createdAt     DateTime  @default(now()) @map("created_at")
  
  @@index([dependentId])
  @@index([employeeId])
  @@index([type])
  @@index([reportStatus])
  @@map("dependent_enrollment_logs")
}

// 眷屬異動歷史
model DependentHistoryLog {
  id           Int      @id @default(autoincrement())
  dependentId  Int      @map("dependent_id")
  dependentName String  @map("dependent_name")
  employeeName String   @map("employee_name")
  action       String   // CREATE, UPDATE, DELETE
  fieldName    String?  @map("field_name")
  oldValue     String?  @map("old_value")
  newValue     String?  @map("new_value")
  changedBy    String   @map("changed_by")
  changedAt    DateTime @default(now()) @map("changed_at")
  
  @@index([dependentId])
  @@index([action])
  @@index([changedAt])
  @@map("dependent_history_logs")
}

// 眷屬申請（員工自助申請加保/退保/變更）
model DependentApplication {
  id              Int       @id @default(autoincrement())
  employeeId      Int       @map("employee_id")
  employeeName    String    @map("employee_name")
  applicationType String    @map("application_type") // ADD（加保）, REMOVE（退保）, UPDATE（變更）
  status          String    @default("PENDING") // PENDING（待審核）, APPROVED（已通過）, REJECTED（已退回）
  
  // 眷屬資料
  dependentId     Int?      @map("dependent_id") // 退保/變更時使用
  dependentName   String    @map("dependent_name")
  relationship    String
  idNumber        String    @map("id_number")
  birthDate       DateTime  @map("birth_date")
  effectiveDate   DateTime  @map("effective_date") // 生效日
  
  // 變更資料（UPDATE 時使用）
  changeField     String?   @map("change_field")
  oldValue        String?   @map("old_value")
  newValue        String?   @map("new_value")
  
  remarks         String?
  
  // 審核資訊
  reviewedBy      String?   @map("reviewed_by")
  reviewedAt      DateTime? @map("reviewed_at")
  reviewNote      String?   @map("review_note")
  
  createdAt       DateTime  @default(now()) @map("created_at")
  
  attachments     DependentApplicationAttachment[]
  
  @@index([employeeId])
  @@index([status])
  @@index([applicationType])
  @@map("dependent_applications")
}

// 眷屬申請附件
model DependentApplicationAttachment {
  id              Int       @id @default(autoincrement())
  applicationId   Int       @map("application_id")
  fileType        String    @map("file_type")     // ID_FRONT, ID_BACK, HOUSEHOLD_REGISTER, HOUSEHOLD_BOOK, OTHER
  fileName        String    @map("file_name")     // 原始檔名
  filePath        String    @map("file_path")     // 儲存路徑
  fileSize        Int       @map("file_size")     // 檔案大小（bytes）
  mimeType        String    @map("mime_type")     // MIME 類型
  uploadedAt      DateTime  @default(now()) @map("uploaded_at")
  
  application     DependentApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  
  @@index([applicationId])
  @@map("dependent_application_attachments")
}

// 勞基法參數設定（勞保與基本工資）
