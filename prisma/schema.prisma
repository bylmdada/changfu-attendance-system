  updatedAt       DateTime  @updatedAt @map("updated_at")
  
  resignation     ResignationRecord @relation(fields: [resignationId], references: [id], onDelete: Cascade)
  
  @@index([resignationId])
  @@index([category])
  @@map("handover_items")
}

// 共用 SMTP 伺服器設定
model SmtpSettings {
  id          Int      @id @default(autoincrement())
  smtpHost    String?  @map("smtp_host")
  smtpPort    Int      @default(587) @map("smtp_port")
  smtpSecure  Boolean  @default(true) @map("smtp_secure")
  smtpUser    String?  @map("smtp_user")
  smtpPassword String? @map("smtp_password")
  fromEmail   String?  @map("from_email")
  fromName    String?  @default("長福考勤系統") @map("from_name")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  @@map("smtp_settings")
}

// 國定假日資料
model Holiday {
  id          Int      @id @default(autoincrement())
  year        Int      // 年份
  date        DateTime // 假日日期
  name        String   // 假日名稱
  description String?  // 說明
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  // 補休記錄關聯
  compensations HolidayCompensation[]
  
  @@unique([date])
  @@index([year])
  @@map("holidays")
}

// 國定假日補休記錄
// 追蹤每位員工的國定假日休假/補休狀態
model HolidayCompensation {
  id               Int       @id @default(autoincrement())
  employeeId       Int       @map("employee_id")
  holidayId        Int       @map("holiday_id")
  holidayDate      DateTime  @map("holiday_date")      // 國定假日原日期
  holidayName      String    @map("holiday_name")      // 國定假日名稱
  workedOnDate     Boolean   @default(false) @map("worked_on_date") // 原日期是否上班
  compensationDate DateTime? @map("compensation_date") // 補休日期
  status           String    @default("PENDING")       // NOT_REQUIRED/PENDING/TAKEN
  year             Int                                  // 年份（用於統計）
  notes            String?                              // 備註
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  holiday  Holiday  @relation(fields: [holidayId], references: [id], onDelete: Cascade)
  
  @@unique([employeeId, holidayId]) // 每位員工每個假日只有一筆記錄
  @@index([employeeId, year])
  @@index([status])
  @@map("holiday_compensations")
}

// 薪資條 Email 發送設定
model PayslipEmailSettings {
